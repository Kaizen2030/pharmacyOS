{
  "name": "pharmacyos-desktop",
  "version": "1.0.0",
  "description": "PharmacyOS Desktop — Dispensary Manager",
  "author": "Julius Kinyua Wanjau",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "obfuscate": "javascript-obfuscator dist --output dist --compact true --control-flow-flattening true --string-array true --string-array-encoding base64 --split-strings true --identifier-names-generator hexadecimal",
    "electron:build": "vite build && npm run obfuscate && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.pharmacyos.desktop",
    "productName": "PharmacyOS",
    "asar": true,
    "asarUnpack": [
      "node_modules/@supabase/**",
      "node_modules/ws/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PharmacyOS",
      "license": "license.txt",
      "unicode": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "dotenv": "^17.4.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "javascript-obfuscator": "^5.4.1",
    "png2icons": "^2.0.1",
    "vite": "^5.0.0"
  }
}
